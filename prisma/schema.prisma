generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  FAILED
  CANCELED
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** Sujet OAuth (Google, etc.) — un compte connecté = un joueur distinct pour le classement. */
  authSub     String? @unique
  displayName String  @default("Demo Player")
  /** Solde in-game en centimes ; 10_000 = 100,00 BS Coin au départ. */
  balance     Int    @default(10000)

  /** XP totale (ouvertures de caisses). */
  xp                       Int @default(0)
  /** Ouvertures gratuites consommables sur POST /api/open (priorité avant le solde). */
  freeCaseOpens            Int @default(0)
  /** Dernier niveau pour lequel les récompenses de passage ont été créditées (départ : 1). */
  enterLevelRewardedUpTo   Int @default(1)

  kycStatus                 KycStatus @default(NONE)
  kycVerifiedAt             DateTime?
  stripeIdentitySessionId   String?   @unique

  /** Abonnement Premium actif tant que la date est dans le futur. */
  premiumUntil            DateTime?
  /** Abonnement Stripe (mise à jour via webhook). */
  stripeSubscriptionId    String?   @unique

  openings    Opening[]
  inventory   InventoryItem[]
  caseBattles CaseBattle[]
  deposits    Deposit[]
}

/** Dépôt Stripe (Checkout) — crédit solde en centimes après paiement confirmé. */
model Deposit {
  id                      String   @id @default(cuid())
  createdAt               DateTime @default(now())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCheckoutSessionId String   @unique
  amountCents             Int
  status                  String
  currency                String   @default("eur")

  @@index([userId, createdAt])
}

model Case {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug  String @unique
  name  String
  price Int

  drops       CaseDrop[]
  openings    Opening[]
  caseBattles CaseBattle[]
}

model Item {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  rarity   Rarity
  value    Int
  imageUrl String?

  drops       CaseDrop[]
  wonIn       Opening?          @relation(fields: [wonInId], references: [id])
  wonInId     String?           @unique
  inventory   InventoryItem[]
  battleRolls CaseBattleRoll[]
}

model CaseDrop {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  caseId String
  itemId String
  weight Int

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([caseId, itemId])
  @@index([caseId])
}

model Opening {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  caseId String

  clientSeed String
  serverSeed String
  nonce      Int
  pricePaid  Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  wonItem Item?

  @@index([userId, createdAt])
  @@index([caseId, createdAt])
}

model InventoryItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  itemId String

  equipped Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([itemId])
}

model CaseBattle {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  caseId String
  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  slots      Int
  /** Nombre de manches : chaque joueur ouvre la caisse une fois par manche. */
  rounds     Int @default(1)
  serverSeed String
  clientSeed String
  totalPaid  Int
  winnerSlot Int

  rolls CaseBattleRoll[]

  @@index([userId, createdAt])
  @@index([caseId, createdAt])
}

model CaseBattleRoll {
  id String @id @default(cuid())

  battleId String
  battle   CaseBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  slotIndex  Int
  roundIndex Int @default(0)
  label      String

  itemId String
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  nonce Int

  @@index([battleId])
}

/** Message envoyé depuis la page Support (démo). */
model SupportMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email   String?
  subject String
  body    String

  @@index([createdAt])
}
